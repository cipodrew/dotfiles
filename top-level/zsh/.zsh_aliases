#### HOME-MANAGER
alias hm="home-manager"

function hm-switch() {
	local lowercase_hostname="$(hostname | tr '[:upper:]' '[:lower:]')"
	home-manager switch --flake ~/dotfiles/home-manager/#"${lowercase_hostname}"
}

# Compare any two generations with fzf. ZSH arrays are 1 indexed
function hm-diff-fzf() {
  local selections=(${(f)"$(home-manager generations | fzf --multi --prompt="Select 2 generations to compare: " | awk '{print $NF}')"})
  
  if [[ ${#selections[@]} -ne 2 ]]; then
    echo "Please select exactly 2 generations"
    return 1
  fi
  
  # Replace "(current)" with actual profile path
  local generations=()
  for gen in $selections; do
    if [[ "$gen" == "(current)" ]]; then
      generations+=(~/.local/state/nix/profiles/home-manager)
    else
      generations+=("$gen")
    fi
  done

  nvd diff "${generations[1]}" "${generations[2]}"
}
# Build and show what will change
function hm-preview() {
  local lowercase_hostname="$(hostname | tr '[:upper:]' '[:lower:]')"
  home-manager build --flake ~/dotfiles/home-manager/#"${lowercase_hostname}" && \
  nvd diff ~/.local/state/nix/profiles/home-manager ./result
  rm -i ./result
}

# Build, preview, and switch if approved
function hm-update() {
  local lowercase_hostname="$(hostname | tr '[:upper:]' '[:lower:]')"
  if home-manager build --flake ~/dotfiles/home-manager/#"${lowercase_hostname}"; then
    nvd diff ~/.local/state/nix/profiles/home-manager ./result
    read -p "Apply these changes? [y/N] " -n 1 -r
    echo
    if [[ $REPLY =~ ^[Yy]$ ]]; then
      home-manager switch --flake ~/dotfiles/home-manager/#"${lowercase_hostname}"
    fi
  fi
  rm -i ./result
}

function hm-edit() {
	local lowercase_hostname="$(hostname | tr '[:upper:]' '[:lower:]')"
	"$EDITOR" ~/dotfiles/home-manager/"${lowercase_hostname}".nix
}

alias yz="yazi"
alias y="yazi"
function ycd() {
	local tmp="$(mktemp -t "yazi-cwd.XXXXXX")"
	yazi "$@" --cwd-file="$tmp"
	if cwd="$(cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
		builtin cd -- "$cwd"
	fi
	rm -f -- "$tmp"
}
alias yy="ycd"

# # Just scan current files (fast)
alias leakscan="nix run nixpkgs#gitleaks -- detect --source . --verbose"
# alias leakscan='nix-shell -p gitleaks --run "gitleaks detect --source . --verbose"'
#
# # Scan last 10 commits (reasonable)
alias leakscan_10='nix run nixpkgs#gitleaks -- detect --source . --log-opts="HEAD~10..HEAD"'
#
# # Full history scan (thorough but slower)
alias leakscan_all=nix run nixpkgs#gitleaks -- detect --source . --log-opts="--all"

alias recap='echo "Ctrl + f -> accept completion

Ctrl + a -> Move to start of line
Ctrl + e -> Move to end of line
Cltr + u -> Cut from cursor to beginning of line
Cltr + k -> Cut from cursor to end of line
Cltr + y -> paste from text buffer, which store what you deleted with ctrl u/k/w

Cltr + w -> delete from cursor to start of word
Ctrl + Shift + _ -> Undo the last changes.
Ctrl + x Ctrl + u -> Undo the last changes.

Alt + b -> back one word
Analogo in avanti con F al posto di B
Alt + d -> delete to end of next word after the cursor
Ctrl + b -> back one char

Alt + r -> Undo all changes to the line.
Alt + Ctrl + e -> Expand command line.
Ctrl + p -> history-search-backward
Ctrl + n -> history-search-forward
fc = fix command in editor
r = repeat commmand, can also substitute arguments eg: r .txt=.md

cd - = go back to previous directory
"

'
