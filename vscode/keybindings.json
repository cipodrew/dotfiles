// Place your key bindings in this file to override the defaultsauto[]
[
    {
        "key": "ctrl+b",
        "command": "workbench.files.action.showActiveFileInExplorer",
        "when": "editorIsOpen && !sideBarFocus"
    },
    {
        "key": "ctrl+n",
        "command": "explorer.newFile",
        "when": "sideBarFocus && !editorFocus"
    },
    {
        "key": "ctrl+d",
        "command": "explorer.newFolder",
        "when": "sideBarFocus && !editorFocus"
    },
    {
        "key": "ctrl+t",
        "command": "workbench.action.terminal.focus",
        "when": "editorFocus && !terminalFocus"
    },
    {
        "key": "ctrl+alt+t",
        "command": "workbench.action.showAllSymbols"
    },
    {
        "key": "ctrl+t",
        "command": "-workbench.action.showAllSymbols"
    },
    {
        "key": "ctrl+e",
        "command": "workbench.action.focusActiveEditorGroup"
    },
    {
        "key": "ctrl+e",
        "command": "-workbench.action.quickOpen"
    },
    {
        "key": "ctrl+shift+7",
        "command": "editor.action.commentLine",
        "when": "editorTextFocus && !editorReadonly"
    },
    {
        "key": "ctrl+oem_2",
        "command": "-editor.action.commentLine",
        "when": "editorTextFocus && !editorReadonly"
    },
    {
        "key": "ctrl+shift+oem_2",
        "command": "editor.action.blockComment",
        "when": "editorTextFocus && !editorReadonly"
    },
    {
        "key": "shift+alt+a",
        "command": "-editor.action.blockComment",
        "when": "editorTextFocus && !editorReadonly"
    },
    {
        "key": "ctrl+w",
        "command": "workbench.action.closeActiveEditor",
        "when": "!terminalFocus"
    },
    {
        "key": "ctrl+w",
        "command": "-workbench.action.closeActiveEditor"
    },
    {
        "key": "ctrl+alt+h",
        "command": "editor.action.startFindReplaceAction",
        "when": "editorFocus || editorIsOpen"
    },
    {
        "key": "ctrl+h",
        "command": "-editor.action.startFindReplaceAction",
        "when": "editorFocus || editorIsOpen"
    },
    {
        "key": "alt+g alt+i",
        "command": "workbench.action.navigateToLastEditLocation"
    },
    {
        "key": "alt+i",
        "command": "workbench.action.navigateForwardInNavigationLocations"
    },
    {
        "key": "alt+o",
        "command": "workbench.action.navigatePreviousInNavigationLocations"
    },
    {
        "key": "ctrl+h",
        "command": "editor.action.showHover",
        "when": "editorTextFocus"
    },
    {
        "key": "ctrl+shift+b b",
        "command": "workbench.action.tasks.build",
        "when": "taskCommandsRegistered"
    },
    {
        "key": "ctrl+shift+b",
        "command": "-workbench.action.tasks.build",
        "when": "taskCommandsRegistered"
    },
    {
        "key": "alt+f g",
        "command": "search.action.openNewEditor"
    },
    {
        "key": "f10",
        "command": "editor.action.peekDefinition",
        "when": "editorHasDefinitionProvider && editorTextFocus && !inReferenceSearchEditor && !isInEmbeddedEditor"
    },
    {
        "key": "alt+f12",
        "command": "-editor.action.peekDefinition",
        "when": "editorHasDefinitionProvider && editorTextFocus && !inReferenceSearchEditor && !isInEmbeddedEditor"
    },
    {
        "key": "tab",
        "command": "selectNextSuggestion",
        "when": "suggestWidgetMultipleSuggestions && suggestWidgetVisible && textInputFocus || suggestWidgetVisible && textInputFocus && !suggestWidgetHasFocusedSuggestion"
    },
    {
        "key": "shift+tab",
        "command": "selectPrevSuggestion",
        "when": "suggestWidgetMultipleSuggestions && suggestWidgetVisible && textInputFocus || suggestWidgetVisible && textInputFocus && !suggestWidgetHasFocusedSuggestion"
    },
    {
        "key": "alt+f",
        "command": "workbench.action.quickTextSearch"
    },
    {
        "key": "tab",
        "command": "workbench.action.quickOpenNavigateNextInFilePicker",
        "when": "inFilesPicker && inQuickOpen"
    },
    {
        "key": "ctrl+shift+p",
        "command": "-workbench.action.quickOpenNavigatePreviousInFilePicker",
        "when": "inFilesPicker && inQuickOpen"
    },
    {
        "key": "ctrl+shift+p",
        "command": "workbench.action.quickOpenNavigatePreviousInFilePicker",
        "when": "inFilesPicker && inQuickOpen"
    },
    {
        "key": "shift+tab",
        "command": "workbench.action.quickOpenNavigatePreviousInFilePicker",
        "when": "inFilesPicker && inQuickOpen"
    },
    {
   //simil-tmux
    {
        "key": "ctrl+shift+space \\",
        "command": "workbench.action.moveEditorToRightGroup"
        // "command": "workbench.action.splitEditorRight"
    },
//    {
//        "key": "ctrl+shift+space oem_5",
//        "command": "workbench.action.splitEditorRight"
//    },
    {
        "key": "ctrl+shift+space oem_6",
        "command": "workbench.action.splitEditorDown"
    },    {
        "key": "alt+l",
        "command": "workbench.action.nextEditorInGroup"
    },
    {
        "key": "alt+h",
        "command": "workbench.action.previousEditorInGroup"
    },
    {
        "key": "ctrl+k ctrl+pageup",
        "command": "-workbench.action.previousEditorInGroup"
    },
    {
        "key": "alt+s",
        "command": "workbench.files.action.saveAllInGroup"
    },
    {
        "key": "shift+f10",
        "command": "editor.action.peekTypeDefinition",
        "when": "editorHasTypeDefinitionProvider && !inReferenceSearchEditor && !isInEmbeddedEditor"
    },
    {
        "key": "ctrl+oem_2",
        "command": "editor.action.commentLine",
        "when": "editorTextFocus && !editorReadonly"
    },
        {
        "key": "ctrl+f",
        "command": "actions.find",
        "when": "editorFocus || editorIsOpen && !terminalFocus"
    },
    {
        "key": "ctrl+f",
        "command": "-actions.find",
        "when": "editorFocus || editorIsOpen"
    },
    {
        "key": "ctrl+shift+f",
        "command": "workbench.action.terminal.focusFind",
        "when": "terminalFindFocused && terminalHasBeenCreated || terminalFindFocused && terminalProcessSupported || terminalFocusInAny && terminalHasBeenCreated || terminalFocusInAny && terminalProcessSupported"
    },
    {
        "key": "ctrl+f",
        "command": "-workbench.action.terminal.focusFind",
        "when": "terminalFindFocused && terminalHasBeenCreated || terminalFindFocused && terminalProcessSupported || terminalFocusInAny && terminalHasBeenCreated || terminalFocusInAny && terminalProcessSupported"
    },
    {
        "key": "ctrl+alt+f",
        "command": "workbench.action.terminal.searchWorkspace",
        "when": "terminalFocus && terminalProcessSupported && terminalTextSelected"
    },
    {
        "key": "ctrl+shift+f",
        "command": "-workbench.action.terminal.searchWorkspace",
        "when": "terminalFocus && terminalProcessSupported && terminalTextSelected"
    },
    {
        "key": "alt+[",
        "command": "editorScroll",
        "args": {
            "by": "line",
            "to": "down",
            // "revealCursor": true, // set to true if you did want to move the cursor
            // false is the default
            "value": 10
        },
        "when": "editorFocus"
    },
    {
        "key": "alt+]",
        "command": "editorScroll",
        "args": {
            "by": "line",
            "to": "up",
            // "revealCursor": true,
            "value": 10
        },
        "when": "editorFocus"
    },    //vimlike cursor scroll
    {
        "key": "ctrl+u", // whatever keybinding you want
        "command": "cursorMove",
        "args": {
            "to": "up",
            "by": "line",
            "value": 10 // change this if you want
        },
        "when": "editorTextFocus"
    },
    {
        "key": "ctrl+e", // whatever keybinding you want
        "command": "cursorMove",
        "args": {
            "to": "down",
            "by": "line",
            "value": 10 // change
        },
        "when": "editorTextFocus"
    },
    {
        "key": "ctrl+shift+u",
        "command": "cursorUndo",
        "when": "textInputFocus"
    },
    {
        "key": "ctrl+u",
        "command": "-cursorUndo",
        "when": "textInputFocus"
    },
        {
        "key": "alt+left",
        "command": "workbench.action.navigateBackInEditLocations",
        "when": "!terminalFocus"
    },
    {
        "key": "alt+right",
        "command": "workbench.action.navigateForwardInEditLocations",
        "when": "!terminalFocus && !cursorAtEndOfQuickInputBox"
    },
]
